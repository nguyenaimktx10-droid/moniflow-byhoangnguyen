# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL của app (Cloud Run). OAuth redirect: ${APP_URL}/auth/callback
APP_URL="https://ais-dev-66zmhcmlsa2rwaopo3s2ot-74012682878.asia-southeast1.run.app"

# Google OAuth — server (server.ts / Cloud Run)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google OAuth — mặc định form popup (copy sang .env.local, không commit)
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_CLIENT_SECRET=
# VITE_APP_URL=

# (Tuỳ chọn) Chỉ khi frontend build tách khác origin với API — URL gốc của backend (không có / cuối)
# VITE_API_BASE_URL=
