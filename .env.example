# GEMINI_API_KEY (tuỳ chọn — AI)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Sheet — Service Account (JSON đầy đủ, một dòng). Chia sẻ bảng với email ...@....iam.gserviceaccount.com (Editor).
# Hoặc dùng GOOGLE_APPLICATION_CREDENTIALS = đường dẫn file key trên máy chủ.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Tuỳ chọn — ID bảng (mặc định: Moni Flow trong repo)
# GOOGLE_SPREADSHEET_ID=

# Khi frontend và API khác domain — URL backend, không có / cuối
# VITE_API_BASE_URL=
